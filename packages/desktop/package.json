{
  "name": "@synapse/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Synapse desktop app (Electron wrapper)",
  "homepage": "https://synapse.ai",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Synapse Team"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "npm --prefix ../.. run build:server && npm run build:main && electron-builder --config electron-builder.yml",
    "build:main": "tsc -p tsconfig.json",
    "dev": "./scripts/dev.sh",
    "dev:win": "powershell ./scripts/dev.ps1",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@synapse/cli": "*",
    "@synapse/unified-daemon": "*",
    "@synapse/client": "*",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "ws": "^8.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.14",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
