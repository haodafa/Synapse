{
  "name": "@synapse/desktop",
  "version": "0.0.2",
  "private": true,
  "description": "Synapse desktop app (Electron wrapper)",
  "homepage": "https://github.com/haodafa/Synapse",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "haodafa"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haodafa/Synapse.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "npm --prefix ../.. run build:unified && npm run build:main && electron-builder --config electron-builder.yml",
    "build:main": "tsc -p tsconfig.json",
    "dev": "./scripts/dev.sh",
    "dev:win": "powershell ./scripts/dev.ps1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@synapse/cli": "*",
    "@synapse/unified-daemon": "*",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "ws": "^8.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/ws": "^8.5.14",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "typescript": "5.9.3",
    "unzip-crx-3": "^0.2.0",
    "vitest": "^4.1.6",
    "wait-on": "8.0.5"
  }
}
