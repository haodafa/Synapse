{
  "name": "@synapse/client",
  "version": "0.0.2",
  "description": "Synapse client SDK package",
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal/daemon-client": {
      "types": "./dist/daemon-client.d.ts",
      "default": "./dist/daemon-client.js"
    },
    "./internal/daemon-client-transport-types": {
      "types": "./dist/daemon-client-transport-types.d.ts",
      "default": "./dist/daemon-client-transport-types.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && tsc -p tsconfig.json --incremental false",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@synapse/protocol": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
