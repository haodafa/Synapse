#!/usr/bin/env node

/**
 * Synapse CLI Entry Point
 * This script is executed when users run the 'synapse' command.
 * It loads the compiled TypeScript/JavaScript from the dist directory.
 */

import { dirname, join } from "path";
import { fileURLToPath } from "url";
import { createRequire } from "module";

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const require = createRequire(import.meta.url);

// Load the main entry point
const distPath = join(__dirname, "..", "dist", "index.js");

// Use require to properly handle CommonJS modules
const { runCli } = await import(distPath);

const exitCode = await runCli(process.argv.slice(2), {
  nodeArgv: [process.argv[0] ?? "node", process.argv[1] ?? "synapse"],
});

process.exitCode = exitCode;

